rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Projects: Anyone can read, only admin can write
    match /projects/{projectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Logs: Anyone can read, only admin can write
    match /logs/{logId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Settings: Anyone can read, only admin can write
    match /settings/contact {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
